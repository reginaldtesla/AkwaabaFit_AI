DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=akwaabafit
DB_USERNAME=akwaabafit
DB_PASSWORD=STRONG_DB_PASSWORD_HERE

SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=false

QUEUE_CONNECTION=database
