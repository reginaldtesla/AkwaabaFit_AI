APP_NAME=AkwaabaFitAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Landing page (GET /) — leave LANDING_APK_URL empty to serve from this server:
# place the file at storage/app/public/downloads/akwaabafit.apk then run: php artisan storage:link
# Or set an external/Drive URL instead:
# LANDING_APK_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=drive_link
# LANDING_APK_FILENAME=akwaabafit.apk
# LANDING_APK_DOWNLOAD_NAME=AkwaabaFit.apk
# LANDING_SUPPORT_EMAIL=support@akwaabafit.com
LANDING_APK_URL=
# Staff usage dashboard (GET /admin) — leave empty to disable
ADMIN_PASSWORD=

# Google Sign-In — Web OAuth client ID (also used as Flutter serverClientId)
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=xxxxx.apps.googleusercontent.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Weather fallback when the phone has no GPS (Open-Meteo — no API key)
WEATHER_DEFAULT_LAT=5.6037
WEATHER_DEFAULT_LON=-0.1870
WEATHER_DEFAULT_LABEL="Accra, GH"
WEATHER_CACHE_MINUTES=15

# Mobile update banner (GET /api/app/version)
APP_ANDROID_LATEST_VERSION=1.0.0
APP_ANDROID_MIN_VERSION=1.0.0
APP_ANDROID_STORE_URL=

# Food scan + AI dietitian coach (Gemini + Hugging Face Ghana model)
HUGGINGFACE_API_TOKEN=
GEMINI_API_KEY=
FOOD_SCAN_MIN_CONFIDENCE=0.30
