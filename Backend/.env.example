APP_NAME=AkwaabaFitAI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Public landing page (GET / on this domain)
# Google Drive share link or direct APK URL (share links are auto-converted to download)
# LANDING_APK_URL=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=drive_link
# LANDING_APK_URL=https://api.tesnet.xyz/downloads/akwaabafit.apk
# LANDING_BETA_FORM_ACTION=
# LANDING_SUPPORT_EMAIL=support@akwaabafit.com
# LANDING_SUPPORT_EMAIL_SUBJECT=AkwaabaFit — Beta / support request

# Staff usage dashboard at /admin (leave empty to disable)
# ADMIN_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Weather via Open-Meteo (free — no API key). Mobile sends GPS ?lat=&lon= on dashboard.
# Fallback when location is off or unavailable:
WEATHER_DEFAULT_LAT=5.6037
WEATHER_DEFAULT_LON=-0.1870
WEATHER_DEFAULT_LABEL="Accra, GH"
WEATHER_CACHE_MINUTES=15

# Mobile app update banner (GET /api/app/version)
APP_ANDROID_LATEST_VERSION=1.0.0
APP_ANDROID_MIN_VERSION=1.0.0
APP_ANDROID_STORE_URL=
APP_IOS_LATEST_VERSION=1.0.0
APP_IOS_MIN_VERSION=1.0.0
APP_IOS_STORE_URL=

# Hybrid food scan (POST /api/nutrition/scan)
# 1) Ghana ConvNeXt on Hugging Face  2) Gemini Flash fallback (free tier at aistudio.google.com)
HUGGINGFACE_API_TOKEN=
FOOD_SCAN_HF_MODEL=Kennethdot/convnext_finetuned_ghanaian_food
FOOD_SCAN_HF_THRESHOLD=0.65
FOOD_SCAN_TIMEOUT=90
GEMINI_API_KEY=
FOOD_SCAN_GEMINI_MODEL=gemini-2.5-flash
# Optional: timeout seconds for Gemini dietitian coaching (default 45)
DIETITIAN_GEMINI_TIMEOUT=45

