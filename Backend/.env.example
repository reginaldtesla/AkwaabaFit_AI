APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=backend
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Use "reverb" for realtime chat + run `php artisan reverb:start` (and set REVERB_* below). "log" is fine for CI.
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local

# Laravel Reverb (Pusher-compatible WebSockets). Host/port must match what mobile/web clients use.
REVERB_APP_ID=akwaaba-local
REVERB_APP_KEY=akwaaba-reverb-key
REVERB_APP_SECRET=akwaaba-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
# Use database (or redis) in production and run `php artisan queue:work` so FCM advice pushes process reliably.
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OpenWeatherMap (Weather + Air Quality)
# Create a key at https://openweathermap.org/
OPENWEATHER_API_KEY=
# Default location if user location isn't available (Accra)
OPENWEATHER_DEFAULT_LAT=5.6037
OPENWEATHER_DEFAULT_LON=-0.1870
OPENWEATHER_DEFAULT_LABEL="Accra, GH"

# Dietetics admin: staff users (is_staff_admin=1) and/or shared key unlock for /admin/dietetics/* and /admin/advice/*
DIETETICS_REVIEW_KEY=
# Set false in production to require staff login only (no shared key).
DIETETICS_ALLOW_SHARED_KEY=true

# Comma-separated case-insensitive substrings that block sending advice chat messages (optional).
CONSULTATION_MESSAGE_BLOCKLIST=

# Paystack (Nutrition Advice payments)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_CURRENCY=GHS
# Amount is in pesewas (GHS * 100). Default: 50.00 GHS
PAYSTACK_ASK_NOW_AMOUNT=5000

# Mobile app update banner (GET /api/app/version)
APP_ANDROID_LATEST_VERSION=1.0.0
APP_ANDROID_MIN_VERSION=1.0.0
APP_ANDROID_STORE_URL=
APP_IOS_LATEST_VERSION=1.0.0
APP_IOS_MIN_VERSION=1.0.0
APP_IOS_STORE_URL=

# Hybrid food scan (POST /api/nutrition/scan)
# 1) Ghana ConvNeXt on Hugging Face  2) Gemini Flash fallback (free tier at aistudio.google.com)
HUGGINGFACE_API_TOKEN=
FOOD_SCAN_HF_MODEL=Kennethdot/convnext_finetuned_ghanaian_food
FOOD_SCAN_HF_THRESHOLD=0.65
FOOD_SCAN_TIMEOUT=90
GEMINI_API_KEY=
FOOD_SCAN_GEMINI_MODEL=gemini-2.5-flash

# Firebase Cloud Messaging (Push notifications)
FCM_PROJECT_ID=
# Place the downloaded service account JSON here (path is gitignored). Example on Windows:
# FCM_SERVICE_ACCOUNT_JSON=C:/path/to/AkwaabaFitAIProject/Backend/storage/app/private/firebase-adminsdk.json
FCM_SERVICE_ACCOUNT_JSON=
